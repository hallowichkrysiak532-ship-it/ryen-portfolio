---
const pages = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Research', href: '/research' },
  { label: 'Projects', href: '/projects' },
  { label: 'Skills', href: '/skills' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav class="navbar">
  <div class="nav-inner">
    <a href={baseUrl + '/'} class="nav-brand">Ryen Wu</a>
    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
    <ul class="nav-links" id="nav-links">
      {pages.map(page => {
        const href = baseUrl + page.href;
        const isActive = currentPath === page.href || currentPath === page.href + '/';
        return (
          <li>
            <a href={href} class={isActive ? 'active' : ''}>{page.label}</a>
          </li>
        );
      })}
    </ul>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-card);
    border-bottom: 1px solid rgba(56, 189, 248, 0.08);
  }

  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .nav-brand {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 18px;
    text-decoration: none;
  }

  .nav-brand:hover {
    text-decoration: none;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 8px;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    color: var(--color-subtext);
    padding: 8px 14px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--color-accent);
    background: rgba(56, 189, 248, 0.08);
    text-decoration: none;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle .bar {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 56px;
      left: 0;
      right: 0;
      flex-direction: column;
      background: var(--color-card);
      padding: 12px 24px;
      border-bottom: 1px solid rgba(56, 189, 248, 0.08);
    }

    .nav-links.open {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      links.classList.toggle('open');
    });
  }
</script>
